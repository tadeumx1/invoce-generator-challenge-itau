# Copy this file to terraform.tfvars and fill in the values for your AWS account.
# terraform.tfvars is .gitignored so secrets / account IDs never land in version control.

account_id  = "123456789012"
region      = "us-east-1"
environment = "dev"
app_name    = "invoice-generator"
vpc_cidr    = "10.42.0.0/16"
