  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// F-AUTH \u2014 auto-login at collection level if accessToken is unset/empty.",
          "// Runs before EVERY request. Skips the actual login request (no recursion).",
          "if (pm.request.url.getPath().endsWith('/api/auth/login')) { return; }",
          "const current = pm.collectionVariables.get('accessToken');",
          "if (current && current.length > 0) { return; }",
          "const baseUrl = pm.collectionVariables.get('baseUrl');",
          "pm.sendRequest({",
          "  url: baseUrl + '/api/auth/login',",
          "  method: 'POST',",
          "  header: { 'Content-Type': 'application/json' },",
          "  body: { mode: 'raw', raw: JSON.stringify({ username: 'demo', password: 'demo123' }) }",
          "}, (err, res) => {",
          "  if (err) { console.error('auto-login failed', err); return; }",
          "  if (res.code !== 200) { console.error('auto-login non-200', res.code, res.text()); return; }",
          "  const body = res.json();",
          "  pm.collectionVariables.set('accessToken', body.access_token);",
          "});"
        ]
      }
    }
  ]
}
