  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/login \u2014 demo user (issues JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('responds 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('returns OAuth2-shaped token response', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access_token');",
                  "  pm.expect(body.access_token).to.match(/^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$/);",
                  "  pm.expect(body.token_type).to.eql('Bearer');",
                  "  pm.expect(body.expires_in).to.be.a('number').and.above(0);",
                  "  pm.expect(body.scope).to.include('invoice:write');",
                  "});",
                  "pm.test('stores access_token on collection variable for downstream requests', function () {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.access_token);",
                  "  pm.expect(pm.collectionVariables.get('accessToken')).to.eql(body.access_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "postman-auth-login"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "F-AUTH demo. Issues an HS256 JWT for the `demo` user (scope `invoice:write`). The collection-level Pre-request script auto-runs this whenever `accessToken` is unset, so subsequent requests just use `Authorization: Bearer {{accessToken}}`."
          }
        },
