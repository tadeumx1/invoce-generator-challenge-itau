{
  "info": {
    "_postman_id": "a1c5e2f4-7d3b-4f9e-9a21-1c0e8b8b1f01",
    "name": "invoice-generator",
    "description": "HTTP collection for the Spring Boot invoice-generator service. Covers the happy paths for both shipped sample payloads (FISICA + JURIDICA SIMPLES_NACIONAL), the legacy alias `POST /api/pedido/gerarNotaFiscal`, and the three documented HTTP 400 rejections (UNSUPPORTED_TAX_REGIME, INVALID_TAX_REGIME, INVALID_DELIVERY_REGION). Every request injects `X-Correlation-Id` so F-OBSERVABILITY MDC / trace correlation is exercised. See `docs/observability.md` for SLI scrape URLs and `docs/postman/README.md` for import + env variable notes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": ""
    }
